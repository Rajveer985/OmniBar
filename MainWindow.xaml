<Window x:Class="WinSpotlight.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WinSpotlight"
        Title="WinSpotlight"
        Width="700"
        SizeToContent="Height"
        MinHeight="68"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <!-- ── ListBoxItem container ─────────────────────────────────────── -->
        <Style x:Key="ResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"                   Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="9"
                                Margin="6,2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Search result item template ──────────────────────────────── -->
        <DataTemplate x:Key="ResultTemplate" DataType="{x:Type local:SearchResult}">
            <Grid Height="56">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Category icon circle -->
                <Border Grid.Column="0"
                        Width="36" Height="36"
                        CornerRadius="9"
                        Background="#2CFFFFFF"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayIcon}"
                               FontSize="17"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"/>
                </Border>

                <!-- Title + subtitle -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="4,0,8,0">
                    <TextBlock Text="{Binding Title}"
                               Foreground="#F2FFFFFF"
                               FontSize="14"
                               FontWeight="Medium"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Subtitle}"
                               Foreground="#66FFFFFF"
                               FontSize="11"
                               Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Category badge -->
                <Border Grid.Column="2"
                        CornerRadius="5"
                        Background="#18FFFFFF"
                        Padding="8,3"
                        Margin="0,0,14,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding CategoryLabel}"
                               Foreground="#55FFFFFF"
                               FontSize="10"
                               FontWeight="SemiBold"
                               TextAlignment="Center"/>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ── Minimal scrollbar ─────────────────────────────────────────── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height"     Value="0"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Spotlight Animations ────────────────────────────────────── -->
        <Storyboard x:Key="ShowAnim">
            <DoubleAnimation Duration="0:0:0.18" To="1" 
                             Storyboard.TargetName="Card" 
                             Storyboard.TargetProperty="Opacity">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Duration="0:0:0.18" From="0.96" To="1" 
                             Storyboard.TargetName="CardScale" 
                             Storyboard.TargetProperty="ScaleX">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Duration="0:0:0.18" From="0.96" To="1" 
                             Storyboard.TargetName="CardScale" 
                             Storyboard.TargetProperty="ScaleY">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="HideAnim">
            <DoubleAnimation Duration="0:0:0.12" To="0" 
                             Storyboard.TargetName="Card" 
                             Storyboard.TargetProperty="Opacity">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Duration="0:0:0.12" To="0.98" 
                             Storyboard.TargetName="CardScale" 
                             Storyboard.TargetProperty="ScaleX">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Duration="0:0:0.12" To="0.98" 
                             Storyboard.TargetName="CardScale" 
                             Storyboard.TargetProperty="ScaleY">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- ── Outer margin gives room for drop-shadow ────────────────────────── -->
    <Border Padding="22">
        <!-- ── Glassmorphic card ───────────────────────────────────────────── -->
        <Border x:Name="Card"
                CornerRadius="16"
                Background="#E51E1E20"
                BorderBrush="#38FFFFFF"
                BorderThickness="1"
                RenderTransformOrigin="0.5,0.5"
                Opacity="0">
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScale" ScaleX="0.96" ScaleY="0.96"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="Black"
                                  BlurRadius="40"
                                  ShadowDepth="8"
                                  Direction="270"
                                  Opacity="0.75"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="68"/>       <!-- search bar -->
                    <RowDefinition Height="Auto"/>     <!-- separator   -->
                    <RowDefinition Height="Auto" MaxHeight="420"/> <!-- results -->
                    <RowDefinition Height="Auto"/>     <!-- footer hint -->
                </Grid.RowDefinitions>

                <!-- ── Search row ──────────────────────────────────────────── -->
                <Grid Grid.Row="0" Margin="18,0,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>  <!-- icon  -->
                        <ColumnDefinition Width="*"/>   <!-- input -->
                        <ColumnDefinition Width="32"/>  <!-- clear -->
                    </Grid.ColumnDefinitions>

                    <!-- 🔍 SVG magnifier -->
                    <Viewbox Grid.Column="0"
                             Width="19" Height="19"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Opacity="0.5">
                        <Canvas Width="24" Height="24">
                            <Ellipse Canvas.Left="3" Canvas.Top="3"
                                     Width="13" Height="13"
                                     Stroke="White" StrokeThickness="2.2"
                                     Fill="Transparent"/>
                            <Line X1="14.5" Y1="14.5" X2="21.5" Y2="21.5"
                                  Stroke="White" StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>

                    <!-- Placeholder overlay -->
                    <TextBlock Grid.Column="1"
                               x:Name="Placeholder"
                               Text="Search apps, files, web…"
                               Foreground="#40FFFFFF"
                               FontSize="21"
                               FontWeight="Light"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox, FallbackValue=0}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Main search TextBox -->
                    <TextBox Grid.Column="1"
                             x:Name="SearchBox"
                             FontSize="21"
                             FontWeight="Light"
                             Foreground="White"
                             CaretBrush="White"
                             SelectionBrush="#5588FF"
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalAlignment="Center"
                             TextChanged="SearchBox_TextChanged"
                             PreviewKeyDown="SearchBox_PreviewKeyDown">
                        <!-- Remove default TextBox border / padding -->
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="0"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <!-- ✕ clear button -->
                    <Button Grid.Column="2"
                            x:Name="ClearBtn"
                            Content="✕"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#55FFFFFF"
                            FontSize="13"
                            Cursor="Hand"
                            Visibility="Collapsed"
                            Click="ClearBtn_Click"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"/>
                </Grid>

                <!-- ── Results Section (Animated) ───────────────────────────── -->
                <StackPanel Grid.Row="1" Grid.RowSpan="3"
                            x:Name="ResultsPanel"
                            Visibility="Collapsed"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="ResultsTranslate" Y="-10"/>
                    </StackPanel.RenderTransform>

                    <!-- ── Thin separator ────── -->
                    <Rectangle x:Name="Separator"
                               Height="0.6"
                               Fill="#28FFFFFF"/>

                    <!-- ── Results ListBox ──────────────────────────────────── -->
                    <ListBox x:Name="ResultsList"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,4,0,4"
                             ItemTemplate="{StaticResource ResultTemplate}"
                             ItemContainerStyle="{StaticResource ResultItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"
                             MaxHeight="420"
                             MouseLeftButtonUp="ResultsList_Click"
                             PreviewKeyDown="ResultsList_PreviewKeyDown"/>

                    <!-- ── Footer hint bar ──────────────────────────────────── -->
                    <Border x:Name="FooterBar"
                            BorderBrush="#18FFFFFF"
                            BorderThickness="0,0.6,0,0"
                            Padding="14,7">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Opacity="0.55">
                            <TextBlock Foreground="White" FontSize="11">
                                <Run Text="↑↓" FontWeight="SemiBold"/>
                                <Run Text="  Navigate   "/>
                                <Run Text="↵" FontWeight="SemiBold"/>
                                <Run Text="  Open   "/>
                                <Run Text="Esc" FontWeight="SemiBold"/>
                                <Run Text="  Close"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
